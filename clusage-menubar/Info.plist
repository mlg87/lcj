<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Binary and bundle identity -->
    <key>CFBundleExecutable</key>
    <string>ClusageMenubar</string>
    <key>CFBundleName</key>
    <string>ClusageMenubar</string>
    <key>CFBundleDisplayName</key>
    <string>Clusage</string>
    <key>CFBundleIdentifier</key>
    <string>com.mlg87.clusage-menubar</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>

    <!-- Hide from Dock and application switcher; show only in menu bar -->
    <key>LSUIElement</key>
    <true/>

    <!-- Minimum macOS: 13.0 (SMAppService for Launch at Login) -->
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>

    <!-- Icon file base name (without .icns extension) -->
    <key>CFBundleIconFile</key>
    <string>ClusageMenubar</string>

    <!-- Version placeholders — build.sh overwrites both from the VERSION file via PlistBuddy -->
    <key>CFBundleShortVersionString</key>
    <string>0.0.0</string>
    <key>CFBundleVersion</key>
    <string>0.0.0</string>
</dict>
</plist>
